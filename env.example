# PostgreSQL connection string used by Prisma (see prisma.config.ts)
DATABASE_URL="postgresql://user:password@localhost:5432/kip?schema=public"

PORT=3000
NODE_ENV=development
JWT_EXPIRY=86400

# Off by default. Set to "true" locally to print full SQL queries to the
# terminal for debugging — never enable this in production.
DEBUG_PRISMA_QUERIES=false
